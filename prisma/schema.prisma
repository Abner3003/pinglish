generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String
  focus           String
  interests       String[]
  acceptedTermsAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum EventProcessingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model EventProcessing {
  id          String                @id @default(uuid())
  consumer    String
  eventId     String
  eventType   String
  aggregateId String?
  status      EventProcessingStatus
  attempts    Int                   @default(1)
  error       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([consumer, eventId])
  @@index([status])
}
