generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String
  focus           String
  interests       String[]
  acceptedTermsAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  responses       LeadResponse[]
}

enum EventProcessingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model EventProcessing {
  id          String                @id @default(uuid())
  consumer    String
  eventId     String
  eventType   String
  aggregateId String?
  status      EventProcessingStatus
  attempts    Int                   @default(1)
  error       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([consumer, eventId])
  @@index([status])
}

model LeadResponse {
  id           String   @id @default(uuid())
  leadId       String
  direction    String
  channel      String
  content      String
  externalFrom String
  createdAt    DateTime @default(now())

  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}
