generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String         @id @default(uuid())
  professionalId  String?
  name            String
  email           String         @unique
  phone           String
  focus           String
  interests       String[]
  acceptedTermsAt DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  professional    Professional?  @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  responses       LeadResponse[]
  contextEntries  LeadContextEntry[]
  planLinks       PlanLead[]
  seat            Seat?
  onboardingStep  OnboardingStep @default(WAITING_OPT_IN)

  @@index([professionalId])
}

model Professional {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  phone                String
  document             String?            @unique
  businessName         String?
  planId               String?
  city                 String?
  state                String?
  age                  Int?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               ProfessionalStatus @default(ACTIVE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  leads                Lead[]
  plans                Plan[]
  portalAccessRequests PortalAccessRequest[]
  seats                Seat[]
  kycProfessional      KycProfessional?
  tenants              Tenant[]
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  phone         String        @unique
  planId        String?
  leagueId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  kycUser       KycUser?
  userChannel   UserChannel?
  league        League?       @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  userJourney   UserJourney?
  learningProfile LearningProfile?
  learningStates UserLearningState[]
  conceptStates UserConceptState[]
  studyPacks    DailyStudyPack[]
  studyEvents    StudyEvent[]

  @@index([leagueId])
}

model KycUser {
  id                  String   @id @default(uuid())
  userId              String   @unique
  personalPreferences String[]
  language            String
  languageLevel       String
  goal                LearningGoal?
  city                String?
  state               String?
  age                 Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycProfessional {
  id             String   @id @default(uuid())
  professionalId String   @unique
  document       String
  city           String
  state          String
  age            Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model UserChannel {
  id                  String            @id @default(uuid())
  userId              String            @unique
  status              UserChannelStatus  @default(ONBOARDING)
  onboardingStep      Int               @default(1)
  awaitingStudyReply  Boolean           @default(false)
  currentPackId       String?
  currentStudyItemId  String?
  lastInboundAt       DateTime?
  lastOutboundAt      DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortalAccessRequest {
  id             String        @id @default(uuid())
  professionalId String?
  name           String
  email          String
  phone          String
  couponCode     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([professionalId])
}

model WhatsAppIntegration {
  id                 String   @id @default(uuid())
  status             String   @default("DRAFT")
  appId             String?
  verifyToken       String?
  accessToken       String?
  businessAccountId String?
  wabaId            String?
  phoneNumberId     String?
  displayPhoneNumber String?
  callbackCode      String?
  callbackState     String?
  metadata          Json?
  connectedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Plan {
  id             String        @id @default(uuid())
  professionalId String?
  name           String
  description    String
  price          Float
  features       String[]
  stripePlanId   String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  leadLinks      PlanLead[]

  @@index([professionalId])
}

model Coupon {
  id         String   @id @default(uuid())
  name       String   @unique
  discount   Float
  validUntil DateTime
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model League {
  id                     String      @id @default(uuid())
  rank                   LeagueRank  @unique
  xpTotalMin             Int
  xpTotalMax             Int?
  xpInRank               Int?
  equivalentActionsApprox Int?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  users                  User[]
  userJourneys           UserJourney[]
}

model Tenant {
  id                  String   @id @default(uuid())
  professionalId      String
  name                String
  description         String
  segment             String
  educationalApproach  Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  professional        Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  learningItems       LearningItem[]
  learningProfiles    LearningProfile[]

  @@index([professionalId])
}

model UserJourney {
  id             String            @id @default(uuid())
  userId         String            @unique
  level          UserJourneyLevel
  leagueId       String
  score          Int               @default(0)
  lastUpdatedAt  DateTime          @updatedAt
  createdAt      DateTime          @default(now())

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  league         League            @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  @@index([leagueId])
}

model LearningProfile {
  id                 String           @id @default(uuid())
  userId             String           @unique
  tenantId           String?
  timezone           String
  nativeLanguage     String
  targetLanguage     String
  goal               LearningGoal
  interests          String[]
  profession         String?
  preferredStudyTime String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant             Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model LearningItem {
  id                   String           @id @default(uuid())
  tenantId             String
  type                 LearningItemType
  text                 String
  meaning              String
  difficulty           Int
  tags                 String[]
  prerequisiteItemIds  String[]
  relatedItemIds       String[]
  metadata             Json
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userStates           UserLearningState[]
  studyEvents          StudyEvent[]

  @@index([tenantId])
  @@index([type])
}

model UserLearningState {
  id                   String                 @id @default(uuid())
  userId               String
  itemId               String
  status               UserLearningStateStatus @default(NEW)
  easeFactor           Float                  @default(2.5)
  intervalDays         Int                    @default(0)
  repetitionCount      Int                    @default(0)
  lastReviewedAt       DateTime?
  nextReviewAt         DateTime?
  lapses               Int                    @default(0)
  consecutiveCorrect   Int                    @default(0)
  consecutiveWrong     Int                    @default(0)
  masteryScore         Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  item                 LearningItem           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
  @@index([nextReviewAt])
}

model UserConceptState {
  id               String   @id @default(uuid())
  userId           String
  topicKey         String
  conceptSeenAt    DateTime?
  lastMode         String?
  lastResult       String?
  lastAnswerQuality Int?
  lastReviewedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicKey])
  @@index([userId])
  @@index([topicKey])
}

model DailyStudyPack {
  id             String          @id @default(uuid())
  userId         String
  date           DateTime
  generatedAt    DateTime        @default(now())
  nextReviewAt   DateTime?
  reviewCount    Int             @default(0)
  items          Json
  targetXp       Int
  completed      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyEvents    StudyEvent[]

  @@unique([userId, date])
  @@index([userId, date])
}

model StudyEvent {
  id             String         @id @default(uuid())
  userId         String
  itemId         String
  packId         String?
  eventType      StudyEventType
  answerQuality  Int?
  isCorrect      Boolean?
  xpEarned       Int?
  occurredAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  item           LearningItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  pack           DailyStudyPack? @relation(fields: [packId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([itemId])
  @@index([packId])
  @@index([occurredAt])
}

model PlanLead {
  id        String   @id @default(uuid())
  planId    String
  leadId    String
  createdAt DateTime @default(now())

  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([planId, leadId])
  @@index([leadId])
}

model Seat {
  id             String     @id @default(uuid())
  professionalId String
  leadId         String?    @unique
  status         SeatStatus @default(AVAILABLE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([professionalId, status])
}

enum EventProcessingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model EventProcessing {
  id          String                @id @default(uuid())
  consumer    String
  eventId     String
  eventType   String
  aggregateId String?
  status      EventProcessingStatus
  attempts    Int                   @default(1)
  error       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([consumer, eventId])
  @@index([status])
}

enum JobRunStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model ScheduledJobRun {
  id           String        @id @default(uuid())
  jobName      String
  scheduledFor String
  status       JobRunStatus  @default(PROCESSING)
  attempts     Int           @default(1)
  lastError    String?
  startedAt    DateTime      @default(now())
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([jobName, scheduledFor])
  @@index([status])
}

enum OnboardingStep {
  WAITING_OPT_IN
  ASK_PROFESSION
  ASK_GOAL
  ASK_INTERESTS
  DONE
}

model LeadResponse {
  id           String   @id @default(uuid())
  leadId       String
  direction    String
  channel      String
  content      String
  externalFrom String
  createdAt    DateTime @default(now())

  lead           Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contextEntries LeadContextEntry[]

  @@index([leadId])
}

model LeadContextEntry {
  id             String         @id @default(uuid())
  leadId         String
  leadResponseId String?        @unique
  source         LeadContextSource
  content        String
  onboardingStep OnboardingStep
  createdAt      DateTime       @default(now())

  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadResponse LeadResponse? @relation(fields: [leadResponseId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

enum LeadContextSource {
  WHATSAPP_INBOUND
}

enum SeatStatus {
  AVAILABLE
  ASSIGNED
  DISABLED
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

enum UserChannelStatus {
  OPT_IN
  OPT_OUT
  ONBOARDING
  OTHER
}

enum LeagueRank {
  D
  C
  B
  A
  S
  SS
}

enum UserJourneyLevel {
  INICIANTE
  PRE_INTERMEDIARIO
  INTERMEDIARIO
  AVANCADO
  PROFICIENTE
}

enum LearningGoal {
  TRAVEL
  WORK
  CONVERSATION
  SCHOOL
  OTHER
}

enum LearningItemType {
  LEXICAL_CHUNK
  PATTERN
  EXAMPLE
  MICRO_LESSON
}

enum UserLearningStateStatus {
  NEW
  LEARNING
  REVIEW
  MASTERED
  SUSPENDED
}

enum StudyEventType {
  ANSWERED
  REVIEWED
  SKIPPED
  LESSON_COMPLETED
}
