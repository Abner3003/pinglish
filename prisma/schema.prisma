generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String         @id @default(uuid())
  professionalId  String?
  name            String
  email           String         @unique
  phone           String
  focus           String
  interests       String[]
  acceptedTermsAt DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  professional    Professional?  @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  responses       LeadResponse[]
  contextEntries  LeadContextEntry[]
  planLinks       PlanLead[]
  seat            Seat?
  onboardingStep  OnboardingStep @default(WAITING_OPT_IN)

  @@index([professionalId])
}

model Professional {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  phone                String
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               ProfessionalStatus @default(ACTIVE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  leads                Lead[]
  plans                Plan[]
  portalAccessRequests PortalAccessRequest[]
  seats                Seat[]
}

model PortalAccessRequest {
  id             String        @id @default(uuid())
  professionalId String?
  name           String
  email          String
  phone          String
  couponCode     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([professionalId])
}

model Plan {
  id             String        @id @default(uuid())
  professionalId String?
  stripePlanId   String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  leadLinks      PlanLead[]

  @@index([professionalId])
}

model PlanLead {
  id        String   @id @default(uuid())
  planId    String
  leadId    String
  createdAt DateTime @default(now())

  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([planId, leadId])
  @@index([leadId])
}

model Seat {
  id             String     @id @default(uuid())
  professionalId String
  leadId         String?    @unique
  status         SeatStatus @default(AVAILABLE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([professionalId, status])
}

enum EventProcessingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model EventProcessing {
  id          String                @id @default(uuid())
  consumer    String
  eventId     String
  eventType   String
  aggregateId String?
  status      EventProcessingStatus
  attempts    Int                   @default(1)
  error       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([consumer, eventId])
  @@index([status])
}

enum OnboardingStep {
  WAITING_OPT_IN
  ASK_PROFESSION
  ASK_GOAL
  ASK_INTERESTS
  DONE
}

model LeadResponse {
  id           String   @id @default(uuid())
  leadId       String
  direction    String
  channel      String
  content      String
  externalFrom String
  createdAt    DateTime @default(now())

  lead           Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contextEntries LeadContextEntry[]

  @@index([leadId])
}

model LeadContextEntry {
  id             String         @id @default(uuid())
  leadId         String
  leadResponseId String?        @unique
  source         LeadContextSource
  content        String
  onboardingStep OnboardingStep
  createdAt      DateTime       @default(now())

  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadResponse LeadResponse? @relation(fields: [leadResponseId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

enum LeadContextSource {
  WHATSAPP_INBOUND
}

enum SeatStatus {
  AVAILABLE
  ASSIGNED
  DISABLED
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}
