{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "sourceMap": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}